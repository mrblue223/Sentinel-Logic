// Network-based detection
SecurityAlert
| summarize AttackCount = count() by AlertName, CompromisedEntity
| top 10 by AttackCount desc
| render barchart

// Or from firewall logs
AzureDiagnostics
| where ResourceType == "NETWORKSECURITYGROUPS"
| where Category == "NetworkSecurityGroupRuleCounter"
| where direction_s == "Inbound"
| where action_s == "Deny"
| summarize BlockedAttempts = count() by destport_d
| top 10 by BlockedAttempts desc
